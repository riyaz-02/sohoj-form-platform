# Gemma 4 Server — Environment Variables
# Copy to .env and fill in your values

# Which Gemma 4 model to load
# Options: gemma-4-12b (needs ~14GB VRAM) | gemma-4-27b (needs ~28GB VRAM)
GEMMA_MODEL=google/gemma-4-12b

# Server port (must match PYTHON_SERVER_URL in Next.js .env.local)
PORT=8000

# Kaggle credentials (needed to download the model)
# Get from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
