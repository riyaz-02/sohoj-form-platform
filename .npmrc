# pnpm v9 — approve build scripts for packages that require native compilation
# These are required for Next.js (sharp), Firebase (protobufjs, @firebase/util),
# and MSW (msw) to function correctly in production.
onlyBuiltDependencies[]=@firebase/util
onlyBuiltDependencies[]=msw
onlyBuiltDependencies[]=protobufjs
onlyBuiltDependencies[]=sharp
